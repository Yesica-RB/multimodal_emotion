cat > .gitignore << 'EOF'
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Entorno virtual
venv/
env/
.env

# Datos grandes (no subir al repo)
data/raw/
*.zip
*.tar.gz

data/raw/data/
data/raw/*.txt
data/processed/

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# MacOS
.DS_Store
.AppleDouble

# VS Code
.vscode/
*.code-workspace

# Modelos guardados (pesados)
*.pt
*.pth
*.bin
*.safetensors

# Resultados intermedios
results/figures/*.png
EOF